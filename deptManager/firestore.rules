rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /debts/{debtId} {
      allow read, write: if request.auth != null;
    }
    match /friendRequests/{requestId} {
      allow read, write: if request.auth != null;
    }
  }
}
